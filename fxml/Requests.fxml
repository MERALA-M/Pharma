<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.RequestsController">
    <children>
        <VBox>
            <Label text="Requests &amp; Prescriptions" styleClass="heading-1" />
            <Label text="Communicate and manage prescriptions" styleClass="text-muted" />
        </VBox>
        
        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <VBox spacing="10" HBox.hgrow="ALWAYS">
                <TableView fx:id="tableRequests" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="100" />
                        <TableColumn fx:id="colCustomer" text="Customer" prefWidth="150" />
                        <TableColumn fx:id="colMessage" text="Message" prefWidth="300" />
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="20" minWidth="350" maxWidth="350">
                <!-- Customer Panel -->
                <VBox fx:id="customerPanel" spacing="10" styleClass="card" visible="false" managed="false">
                    <Label text="New Request" styleClass="heading-2" />
                    <TextArea fx:id="txtNewRequest" prefHeight="100" promptText="Type your message or prescription details..." wrapText="true" />
                    <Button fx:id="btnSendRequest" text="Send Request" styleClass="btn-primary" onAction="#handleSendRequest" maxWidth="Infinity">
                        <graphic>
                            <FontAwesomeIconView glyphName="PAPER_PLANE" fill="white" />
                        </graphic>
                    </Button>
                    <Label text="Reply from Pharmacist:" styleClass="text-muted" style="-fx-font-weight: bold; -fx-padding: 10 0 0 0;" />
                    <TextArea fx:id="txtViewReply" prefHeight="100" editable="false" wrapText="true" style="-fx-background-color: #F8FAFC;" />
                </VBox>

                <!-- Pharmacist/Admin Panel -->
                <VBox fx:id="pharmacistPanel" spacing="10" styleClass="card" visible="false" managed="false">
                    <Label text="Manage Request" styleClass="heading-2" />
                    <Label text="Status" />
                    <ComboBox fx:id="cmbStatus" maxWidth="Infinity" styleClass="text-field" />
                    <Label text="Reply to Customer" />
                    <TextArea fx:id="txtReply" prefHeight="100" promptText="Type your reply..." wrapText="true" />
                    <Button fx:id="btnSendReply" text="Update &amp; Send Reply" styleClass="btn-primary" onAction="#handleSendReply" maxWidth="Infinity">
                        <graphic>
                            <FontAwesomeIconView glyphName="REPLY" fill="white" />
                        </graphic>
                    </Button>
                </VBox>
            </VBox>
        </HBox>
    </children>
</VBox>
