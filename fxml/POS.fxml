<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<HBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.POSController" style="-fx-background-color: #f1f5f9;">
    <padding>
        <Insets bottom="10" left="15" right="15" top="10" />
    </padding>

    <!-- Left: Product Selection -->
    <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Inventory Items" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtSearchMed" promptText="Search medicines..." prefWidth="250" style="-fx-background-radius: 20;" />
        </HBox>
        
        <TableView fx:id="tableMedicines" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8;">
            <columns>
                <TableColumn fx:id="colMedName" text="Name" prefWidth="200" />
                <TableColumn fx:id="colMedPrice" text="Price" prefWidth="80" />
                <TableColumn fx:id="colMedQty" text="Stock" prefWidth="80" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: #f8fafc; -fx-background-radius: 8;">
            <Label text="Quantity to add:" style="-fx-font-weight: bold;" />
            <TextField fx:id="txtAddQty" prefWidth="60" text="1" alignment="CENTER" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Add to Cart" onAction="#handleAddToCart" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;">
                <graphic>
                    <FontAwesomeIconView glyphName="PLUS_CIRCLE" fill="white" />
                </graphic>
            </Button>
        </HBox>
    </VBox>

    <!-- Right: Current Sale -->
    <VBox spacing="10" prefWidth="400" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
        <Label text="Checkout Details" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
        
        <VBox spacing="5">
            <Label text="Select Customer" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
            <ComboBox fx:id="cmbCustomer" maxWidth="Infinity" style="-fx-background-radius: 8;" />
        </VBox>
        
        <TableView fx:id="tableCart" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8;">
            <columns>
                <TableColumn fx:id="colCartName" text="Item" prefWidth="150" />
                <TableColumn fx:id="colCartQty" text="Qty" prefWidth="60" />
                <TableColumn fx:id="colCartTotal" text="Total" prefWidth="100" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox spacing="10">
            <Button text="-" onAction="#handleDecreaseQty" style="-fx-min-width: 40;" />
            <Button text="+" onAction="#handleIncreaseQty" style="-fx-min-width: 40;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Remove" onAction="#handleRemoveFromCart" style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-font-weight: bold;" />
        </HBox>

        <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f8fafc; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
            <HBox>
                <Label text="Subtotal" style="-fx-text-fill: #64748b;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblSubtotal" text="0.00" style="-fx-font-weight: bold;" />
            </HBox>
            <HBox>
                <Label text="Tax (5%)" style="-fx-text-fill: #64748b;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTax" text="0.00" style="-fx-font-weight: bold;" />
            </HBox>
            <HBox>
                <Label text="Total" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #0f172a;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTotal" text="0.00" style="-fx-font-size: 20px; -fx-font-weight: 900; -fx-text-fill: #2563eb;" />
            </HBox>
        </VBox>

        <VBox spacing="5">
            <Label text="Payment Method" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b;" />
            <ComboBox fx:id="cmbPayment" maxWidth="Infinity" style="-fx-background-radius: 8;" />
        </VBox>
        
        <Button text="Process Sale &amp; Print" onAction="#handleCheckout" maxWidth="Infinity" prefHeight="45" 
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 10; -fx-cursor: hand;">
            <graphic>
                <FontAwesomeIconView glyphName="PRINT" fill="white" />
            </graphic>
        </Button>
    </VBox>
</HBox>
