<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="500.0" prefWidth="450.0" styleClass="dialog-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.MedicineDialogController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <Label styleClass="heading-2" text="Medicine Details" />
            
            <GridPane hgap="10.0" vgap="15.0" VBox.vgrow="ALWAYS">
              <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="150.0" minWidth="100.0" prefWidth="120.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="280.0" minWidth="10.0" prefWidth="250.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="60.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Medicine ID" />
                  <TextField fx:id="txtId" editable="false" styleClass="text-field-disabled" GridPane.columnIndex="1" />
                  
                  <Label text="Name" GridPane.rowIndex="1" />
                  <TextField fx:id="txtName" promptText="Enter medicine name" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  
                  <Label text="Category" GridPane.rowIndex="2" />
                  <ComboBox fx:id="cbCategory" prefWidth="280.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  
                  <Label text="Price ($)" GridPane.rowIndex="3" />
                  <TextField fx:id="txtPrice" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  
                  <Label text="Quantity" GridPane.rowIndex="4" />
                  <TextField fx:id="txtQuantity" promptText="0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  
                  <Label text="Expiry Date" GridPane.rowIndex="5" />
                  <DatePicker fx:id="dpExpiryDate" prefWidth="280.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                  
                  <Label text="Supplier ID" GridPane.rowIndex="6" />
                  <TextField fx:id="txtSupplier" promptText="Enter supplier ID" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                  
                  <Label text="Description" GridPane.rowIndex="7" GridPane.valignment="TOP">
                     <GridPane.margin>
                        <Insets top="5.0" />
                     </GridPane.margin>
                  </Label>
                  <TextArea fx:id="txtDescription" prefHeight="60.0" prefWidth="200.0" promptText="Enter description..." wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="7" />
               </children>
            </GridPane>
            
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button fx:id="btnCancel" cancelButton="true" mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-secondary" text="Cancel" />
                  <Button fx:id="btnSave" defaultButton="true" mnemonicParsing="false" onAction="#handleSave" styleClass="btn-primary" text="Save" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
