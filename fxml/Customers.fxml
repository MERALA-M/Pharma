<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.CustomersController">
    <children>
        <HBox alignment="CENTER_LEFT" styleClass="top-header" style="-fx-padding: 0 0 20 0;">
            <Label text="Customers Management" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2B2D42;" />
        </HBox>

        <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10">
            <TableView fx:id="tableCustomers" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="100" />
                    <TableColumn fx:id="colName" text="Name" prefWidth="250" />
                    <TableColumn fx:id="colPhone" text="Phone" prefWidth="150" />
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="200" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </children>
</VBox>
