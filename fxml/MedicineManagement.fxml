<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.MedicineController">
    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Medicine Inventory" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
        <TextField fx:id="txtSearch" promptText="Search medicines..." HBox.hgrow="ALWAYS" />
        <Button fx:id="btnAdd" text="Add New" onAction="#handleAddMedicine" style="-fx-background-color: #2563eb; -fx-text-fill: white;" />
    </HBox>

    <TableView fx:id="tableMedicines" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60" />
            <TableColumn fx:id="colName" text="Name" prefWidth="180" />
            <TableColumn fx:id="colCategory" text="Category" prefWidth="120" />
            <TableColumn fx:id="colPrice" text="Price" prefWidth="80" />
            <TableColumn fx:id="colQuantity" text="Stock" prefWidth="80" />
            <TableColumn fx:id="colExpiry" text="Expiry" prefWidth="100" />
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
        </columns>
    </TableView>

    <HBox fx:id="actionBox" spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnEdit" text="Edit" onAction="#handleEditMedicine" />
        <Button fx:id="btnUpdateStock" text="Update Stock" onAction="#handleUpdateStock" />
        <Button fx:id="btnDelete" text="Delete" onAction="#handleDeleteMedicine" style="-fx-background-color: #ef4444; -fx-text-fill: white;" />
        <Button fx:id="btnUndo" text="Undo" onAction="#handleUndo" />
        <Button fx:id="btnClone" text="Clone (Prototype)" onAction="#handleCloneMedicine" />
        <Button fx:id="btnHierarchy" text="Hierarchy (Composite)" onAction="#handleShowComposite" style="-fx-background-color: #8b5cf6; -fx-text-fill: white;" />
    </HBox>
</VBox>
