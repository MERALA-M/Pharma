<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="25" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.ProfileController">
    <VBox alignment="CENTER" spacing="10">
        <Label text="My Profile" styleClass="heading-1" />
        <Label text="Manage your account information" styleClass="text-muted" />
    </VBox>
    
    <VBox styleClass="card" spacing="30" maxWidth="500" alignment="CENTER" style="-fx-padding: 40;">
        <StackPane>
            <Circle fx:id="avatarCircle" fill="#E2E8F0" radius="50" />
            <FontAwesomeIconView fx:id="avatarIcon" glyphName="USER" size="40" fill="white" />
        </StackPane>
        
        <VBox alignment="CENTER" spacing="5">
            <Label fx:id="lblName" text="Full Name" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #0F172A;" />
            <Label fx:id="lblUsername" text="@username" style="-fx-font-size: 14px; -fx-text-fill: #64748B;" />
        </VBox>
        
        <HBox alignment="CENTER">
            <Label fx:id="lblRole" text="ROLE" styleClass="badge-role" style="-fx-padding: 5 15; -fx-font-size: 14px;" />
        </HBox>
        
        <Region style="-fx-background-color: #E2E8F0; -fx-pref-height: 1px; -fx-min-width: 300px;" />
        
        <VBox spacing="15" alignment="CENTER_LEFT" maxWidth="300">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <FontAwesomeIconView glyphName="ENVELOPE" size="16" fill="#94A3B8" />
                <VBox>
                    <Label text="Email Address" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;" />
                    <Label fx:id="lblEmail" text="user@example.com" style="-fx-font-size: 14px; -fx-text-fill: #334155;" />
                </VBox>
            </HBox>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <FontAwesomeIconView glyphName="PHONE" size="16" fill="#94A3B8" />
                <VBox>
                    <Label text="Phone Number" style="-fx-font-size: 11px; -fx-text-fill: #94A3B8; -fx-font-weight: bold;" />
                    <Label fx:id="lblPhone" text="+1 (555) 000-0000" style="-fx-font-size: 14px; -fx-text-fill: #334155;" />
                </VBox>
            </HBox>
        </VBox>
        
        <Button text="Secure Logout" styleClass="btn-danger" onAction="#handleLogout" style="-fx-padding: 12 40; -fx-font-size: 14px;">
            <graphic>
                <FontAwesomeIconView glyphName="SIGN_OUT" fill="white" />
            </graphic>
        </Button>
    </VBox>
</VBox>
