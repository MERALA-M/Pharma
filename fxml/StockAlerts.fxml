<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.StockAlertsController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label fx:id="lblTitle" text="Stock Alerts &amp; Pharmacist Requests" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
    
    <TableView fx:id="tableAlerts" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-overflow-hidden: true;">
        <columns>
            <TableColumn fx:id="colMedicine" text="Medicine" prefWidth="180" />
            <TableColumn fx:id="colPharmacist" text="Requested By" prefWidth="120" />
            <TableColumn fx:id="colPriority" text="Priority" prefWidth="100" />
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
            <TableColumn fx:id="colMessage" text="Message" prefWidth="300" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox fx:id="adminActionsBox" spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0;">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Admin Actions" style="-fx-font-weight: bold;" />
            <Label text="Update medicine quantity or resolve the selected request." style="-fx-text-fill: #64748b; -fx-font-size: 12px;" />
        </VBox>
        <Button text="Restock (Update Qty)" onAction="#handleRestock" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;" />
        <Button text="Mark as Resolved" onAction="#handleResolve" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;" />
    </HBox>
</VBox>
