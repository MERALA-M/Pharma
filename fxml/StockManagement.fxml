<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.StockController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Inventory Management" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" />
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="txtSearch" promptText="Quick search..." prefWidth="250" style="-fx-background-radius: 20;" />
    </HBox>
    
    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="All Medicines" style="-fx-font-weight: bold; -fx-text-fill: #64748b;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="View Catalog Hierarchy" onAction="#handleShowHierarchy" style="-fx-background-color: #f1f5f9; -fx-text-fill: #6366f1; -fx-font-weight: bold; -fx-font-size: 11px;" />
        </HBox>
        <TableView fx:id="tableMedicines" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8;">
            <columns>
                <TableColumn fx:id="colName" text="Medicine Name" prefWidth="250" />
                <TableColumn fx:id="colCategory" text="Category" prefWidth="150" />
                <TableColumn fx:id="colPrice" text="Price" prefWidth="100" />
                <TableColumn fx:id="colQuantity" text="Stock Qty" prefWidth="100" />
                <TableColumn fx:id="colStatus" text="Status" prefWidth="120" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <HBox spacing="20">
        <!-- Pharmacist Stock Request Section -->
        <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12;">
            <Label text="📢 Request Stock Replenishment" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0f172a;" />
            <Label text="Notify Admin to restock the selected medicine." style="-fx-text-fill: #64748b; -fx-font-size: 12px;" />
            
            <HBox spacing="10" alignment="BOTTOM_LEFT">
                <VBox spacing="5">
                    <Label text="Priority" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                    <ComboBox fx:id="cmbPriority" prefWidth="120" />
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Message to Admin" style="-fx-font-size: 11px; -fx-font-weight: bold;" />
                    <TextField fx:id="txtRequestMsg" promptText="Explain why this is needed (e.g. Critical for surgery)" />
                </VBox>
                <Button text="Send Stock Request" onAction="#handleSendRequest" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;" />
            </HBox>
        </VBox>
        
        <!-- Admin/Staff Update Section -->
        <VBox spacing="10" style="-fx-background-color: #f1f5f9; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-min-width: 250;">
            <Label text="⚙️ Quick Actions" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #0f172a;" />
            <Button text="Update Selected Stock" onAction="#handleUpdateStock" maxWidth="Infinity" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10;" />
            <Label text="Staff can update quantities only." style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-alignment: center;" />
        </VBox>
    </HBox>
</VBox>
