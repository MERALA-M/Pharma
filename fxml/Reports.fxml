<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.ReportsController">
    <children>
        <HBox alignment="CENTER_LEFT" styleClass="top-header" style="-fx-padding: 0 0 20 0;">
            <Label text="System Reports" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2B2D42;" />
        </HBox>

        <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10">
            <HBox spacing="10">
                <Button text="Generate Inventory Report" styleClass="btn-primary" onAction="#handleInventoryReport" />
                <Button text="Generate Sales Report" styleClass="btn-primary" onAction="#handleSalesReport" />
                <Button text="Generate Revenue Report" styleClass="btn-secondary" onAction="#handleRevenueReport" />
            </HBox>
            
            <Label text="Report Output (Template Method Pattern)" styleClass="card-title" />
            <TextArea fx:id="txtReportOutput" VBox.vgrow="ALWAYS" styleClass="text-field" style="-fx-font-family: 'Consolas', monospace;" editable="false" />
        </VBox>
    </children>
</VBox>
