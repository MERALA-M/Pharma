<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.OrdersHistoryController">
    <VBox>
        <Label text="Order &amp; Invoice History" styleClass="heading-1" />
        <Label text="View your past orders" styleClass="text-muted" />
    </VBox>
    
    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="15">
        <TableView fx:id="tableOrders" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="Invoice ID" prefWidth="120" />
                <TableColumn fx:id="colDate" text="Date" prefWidth="150" />
                <TableColumn fx:id="colItems" text="Items" prefWidth="250" />
                <TableColumn fx:id="colPayment" text="Payment Method" prefWidth="150" />
                <TableColumn fx:id="colTotal" text="Total ($)" prefWidth="100" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
