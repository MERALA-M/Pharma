<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="15" prefWidth="400" prefHeight="500" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pharmacy.controller.HierarchyDialogController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label text="📂 Medicine Category Hierarchy" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" />
    <Label text="Visual representation of the Composite Pattern structure." style="-fx-text-fill: #64748b; -fx-font-size: 12px;" />

    <TreeView fx:id="treeHierarchy" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" />

    <HBox alignment="CENTER_RIGHT">
        <Button text="Close" onAction="#handleClose" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 5;" />
    </HBox>
</VBox>
